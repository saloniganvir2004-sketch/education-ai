# ==========================================
# Education AI Backend Configuration
# ==========================================

# ---------- OpenAI ----------
OPENAI_API_KEY=your_openai_api_key

# ---------- AssemblyAI ----------
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=education_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# Optional SQLAlchemy URL (leave blank if generated automatically)
DATABASE_URL=

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ---------- Application ----------
APP_HOST=127.0.0.1
APP_PORT=8000
DEBUG=False

# ---------- Uploads ----------
UPLOAD_FOLDER=uploads

# ---------- Embeddings ----------
EMBEDDING_MODEL=text-embedding-3-small

# ---------- Chat Model ----------
CHAT_MODEL=gpt-5-nano

# ---------- Retrieval ----------
TOP_K=5
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---------- Cache ----------
CACHE_ENABLED=True

# ---------- Conversation ----------
CONVERSATION_MEMORY=True